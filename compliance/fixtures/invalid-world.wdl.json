  "laws": [
    {
      "metadata": {
        "explanation": "Unavailable garments cannot be recommended as wearable today."
      },
      "id": "law_garment_available",
      "name": "Garments must be available before recommendation",
      "scope": "world",
      "appliesTo": {
        "kind": "type",
        "value": "garment"
      },
      "condition": {
        "op": "equals",
        "left": {
          "kind": "path",
          "path": "aspects.application.availability.status"
        },
        "right": {
          "kind": "literal",
          "value": "available"
        }
      },
      "outcome": "reject",
      "severity": "error"
    },
    {
      "metadata": {
        "explanation": "Measurements are private; viewing them requires household permission."
      },
      "id": "law_measurements_private",
      "name": "Private measurements cannot be projected without permission",
      "scope": "world",
      "appliesTo": {
        "kind": "type",
        "value": "person"
      },
      "condition": {
        "op": "has_authority",
        "actorRef": {
          "kind": "actor",
          "field": "id"
        },
        "capability": "household.measurements.view"
      },
      "outcome": "reject",
      "severity": "error"
    },
    {
      "metadata": {
        "explanation": "An outfit plan enters Reality only after the family accepts it."
      },
      "id": "law_candidate_acceptance",
      "name": "Candidate outfits do not become Reality until accepted",
      "scope": "world",
      "appliesTo": {
        "kind": "type",
        "value": "outfit_plan"
      },
      "condition": {
        "op": "any",
        "conditions": [
          {
            "op": "equals",
            "left": {
              "kind": "path",
              "path": "aspects.state.status"
            },
            "right": {
              "kind": "literal",
              "value": "accepted"
            }
          },
          {
            "op": "contains",
            "left": {
              "kind": "context",
              "key": "candidateWorldId"
            },
            "right": {
              "kind": "literal",
              "value": "cw_"
            }
          }
        ]
      },
      "outcome": "reject",
      "severity": "error"
    }
  ],
  "traversals": [
    {
      "rules": [
        {
          "follow": "includes_person",
